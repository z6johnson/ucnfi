# LiteLLM (TritonAI) — preferred provider for /api/chat.
LITELLM_API_KEY=
# Optional override; defaults to https://tritonai-api.ucsd.edu
LITELLM_BASE_URL=

# Anthropic — fallback provider. Used automatically if LITELLM_API_KEY
# is unset or if the LiteLLM stream errors before any tokens are sent.
ANTHROPIC_API_KEY=

# Admin gate for editing routes (e.g. /memos/new). Cookie is an HMAC
# keyed by this value, so rotating it invalidates every session.
ADMIN_PASSWORD=

# GitHub-as-CMS for memo publishing. POST /api/memos commits a markdown
# file to this repo; Vercel's Git integration rebuilds and publishes
# the memo (~60s).
# GITHUB_TOKEN: fine-grained PAT with Contents: Read and write on the
#   single repo below. No account permissions. Rotate on expiry.
# GITHUB_REPO: owner/repo target for the commit.
# GITHUB_BRANCH: optional, defaults to "main".
GITHUB_TOKEN=
GITHUB_REPO=z6johnson/ucnfi
GITHUB_BRANCH=main

# Postgres — planned for Step 3 (saved chats + shares). Not used yet.
DATABASE_URL=

# Public base URL for share links — added in Step 3
NFI_BASE_URL=http://localhost:3000
